{
  "name": "fuse-browser",
  "version": "0.1.0",
  "description": "Navigateur agentique Fusengine pour agents IA (MCP + CLI) au-dessus de Patchright/Playwright",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "fuse-browser": "dist/bin/cli.js",
    "fuse-browser-mcp": "dist/bin/mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "proxies.example.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test tests/unit",
    "test:integration": "node --test --import tsx tests/integration/mcp.test.ts tests/integration/probe.test.ts tests/integration/snapshot.test.ts tests/integration/run.test.ts tests/integration/extract-schema.test.ts",
    "browsers": "patchright install chromium",
    "mcp": "node --import tsx src/bin/mcp.ts",
    "cli": "node --import tsx src/bin/cli.ts"
  },
  "trustedDependencies": [
    "patchright",
    "playwright"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "patchright": "^1.60.1",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
